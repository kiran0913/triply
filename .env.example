# Triply - Environment Variables
# See README and VERCEL_DEPLOYMENT_CHECKLIST.md for setup.

# Database - Supabase (required)
# Get from Supabase Dashboard → Project Settings → Database
# Replace [REGION] with your region (e.g. us-east-1, eu-west-1)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres"

# Auth (required in production)
JWT_SECRET="your-secret-min-32-chars"

# App URL (required for production: email links, OG metadata)
APP_BASE_URL="http://localhost:3000"

# NextAuth (optional)
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI - local Ollama (local dev only; set ENABLE_LOCAL_AI=false or leave unset on Vercel)
ENABLE_LOCAL_AI=true
OLLAMA_URL="http://localhost:11434"
LOCAL_AI_MODEL="mistral"

# Admin (comma-separated emails)
ADMIN_EMAILS="admin@example.com"

# Email (Resend) - verification emails
RESEND_API_KEY=""
EMAIL_FROM="Triply <onboarding@resend.dev>"

# Cron (optional; required if using Vercel Cron to hit /api/cron/*)
CRON_SECRET="random-secret-min-32-chars"

# Sentry (optional)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""
