# Triply - Environment Variables
# See README for setup instructions

# Database - Supabase
# Get connection strings from Supabase Dashboard → Project Settings → Database
# Replace [REGION] with your region (e.g. us-east-1, eu-west-1)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres"

# Auth (required)
JWT_SECRET="your-secret-min-32-chars"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI - local Ollama
ENABLE_LOCAL_AI=true
OLLAMA_URL="http://localhost:11434"
LOCAL_AI_MODEL="mistral"

# Admin (comma-separated emails)
ADMIN_EMAILS="admin@example.com"

# Email (Resend) - Triply uses Resend for verification emails
RESEND_API_KEY=""
APP_BASE_URL="http://localhost:3000"

# Cron
CRON_SECRET="random-secret-min-32-chars"
